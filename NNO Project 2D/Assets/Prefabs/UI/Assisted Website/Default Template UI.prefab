    - target: {fileID: 4434785676528339645, guid: b587921eb8b264a4799a34bbdb5218e0, type: 3}
      propertyPath: m_text
      value: 'Four years after his revolutionary  Third Symphony , Beethoven wrote
        his  Violin Concerto . It is one of the works you must hear at least once.
        It has something that touches you, whether you are a frequent concertgoer
        or not. '
      objectReference: {fileID: 0}
