    - target: {fileID: 5712258067148907105, guid: b587921eb8b264a4799a34bbdb5218e0, type: 3}
      propertyPath: m_text
      value: 'The Pieter Roelf Youth Concerts are a major educational project that
        annually introduces thousands of children to live symphonic music in the
        three northern provinces. This project can only exist thanks to the support
        of funds and private contributions. '
      objectReference: {fileID: 0}
