    - target: {fileID: 8549811231997373532, guid: b587921eb8b264a4799a34bbdb5218e0, type: 3}
      propertyPath: m_text
      value: "A Friend of the NNO, Gerda wants to give children the opportunity to
        develop a love for classical music \u2013 something she, in hindsight, missed
        in her life as a child. 'When I am no longer here, something will remain.
        Who do I wish it for?'"
      objectReference: {fileID: 0}
